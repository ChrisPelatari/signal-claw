# signal-claw configuration. Copy to config.env and fill in real values.
# config.env is gitignored — never commit your actual numbers.

# The Signal number this daemon is linked to (your primary Signal account number,
# since signal-cli's link mode reuses the primary's number).
export SIGNAL_ACCOUNT="+15551230000"

# A trusted sender. Direct messages from this number bypass the trigger word
# and are passed straight to claude.
export SIGNAL_HOMELINE="+15554560000"

# Per-host routing. Messages (homeline DMs and note-to-self) MUST start with
# "${TRIGGER_WORD}@${SIGNAL_HOSTNAME}" or they are dropped silently. This lets
# one Signal account drive a fleet of machines without every host answering
# every message. Defaults below produce a prefix of "claude@<short-hostname>".
# Bare "pulse-agents" bypasses the prefix as a fleet-wide ping.
export TRIGGER_WORD="claude"
# export SIGNAL_HOSTNAME="jiraiya"   # defaults to `hostname -s` if unset

# Absolute paths to the signal-cli and claude binaries.
export SIGNAL_CLI="${HOME}/.local/bin/signal-cli"
export CLAUDE="${HOME}/.local/bin/claude"

# Where the daemon writes its log + where signal-cli stores account state
# (this is also where signal-cli's data dir lives, by default in
# $XDG_DATA_HOME/signal-cli — keep them on the same machine).
export STATE_DIR="${HOME}/.local/share/signal-claude"

# Where the per-channel Claude session IDs are persisted (JSON file).
# One UUID per channel — homeline gets its own thread, note-to-self its own.
export SESSIONS_FILE="${HOME}/.local/share/signal-claude/sessions.json"

# Tunables.
export CLAUDE_TIMEOUT=240
export SIGNAL_RETRY=5
export MAX_REPLY_LEN=3800

# Watchdog. signal-cli's ReceiveHelper can wedge silently (websocket dies,
# reconnect loop gives up, process stays alive). Every WATCHDOG_PROBE seconds
# the daemon round-trips a 'version' rpc call — no answer means the child is
# dead, recycle it. Independently, if no inbound traffic (receive events or
# stderr chatter) arrives for WATCHDOG_STALE seconds, recycle preventively;
# Signal queues messages server-side, so a recycle never loses anything.
export WATCHDOG_PROBE=300     # 5 min
export WATCHDOG_STALE=14400   # 4 h
